{
  "name": "opencode-vscode-client",
  "publisher": "fiyqkrc",
  "version": "0.1.40",
  "displayName": "OpenCode VS Code Client",
  "description": "AI programming assistant sidebar for OpenCode with multi-session chat, editor context, terminal analysis, and review tools.",
  "icon": "assets/icon.png",
  "license": "MIT",
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "opencode",
    "ai",
    "coding-assistant",
    "agent",
    "chat",
    "sdk",
    "sidebar",
    "terminal",
    "code-review",
    "diff",
    "developer-tools"
  ],
  "galleryBanner": {
    "color": "#0E639C",
    "theme": "dark"
  },
  "pricing": "Free",
  "markdown": "github",
  "qna": "marketplace",
  "repository": {
    "type": "git",
    "url": "https://github.com/pengjiantao/opencode-vscode-client.git"
  },
  "bugs": {
    "url": "https://github.com/pengjiantao/opencode-vscode-client/issues"
  },
  "homepage": "https://github.com/pengjiantao/opencode-vscode-client#readme",
  "main": "./dist/extension/index.js",
  "activationEvents": [
    "onView:opencode-sidebar.main",
    "onCommand:opencode-sidebar.focus",
    "onCommand:opencode-sidebar.sendSelectionToOpencode",
    "onCommand:opencode-sidebar.explainSelectionToOpencode",
    "onCommand:opencode-sidebar.sendTerminalToOpencode",
    "onCommand:opencode-sidebar.explainTerminalToOpencode",
    "onCommand:opencode-sidebar.pasteAsPlainText"
  ],
  "engines": {
    "vscode": "^1.65.0"
  },
  "scripts": {
    "test": "npm run test:extension && npm run test:webview",
    "test:extension": "vitest run --config vitest.config.extension.ts",
    "test:webview": "vitest run --config vitest.config.webview.ts",
    "test:watch": "vitest --config vitest.config.webview.ts --watch",
    "build": "npm run build:webview && npm run build:extension",
    "build:webview": "vite build",
    "build:extension": "tsc -p tsconfig.extension.json && npm run bundle:extension",
    "bundle:extension": "esbuild dist/extension/extension/index.js --bundle --platform=node --outdir=dist/extension --external:vscode --format=cjs --sourcemap --allow-overwrite",
    "lint": "eslint . && tsc --noEmit -p tsconfig.eslint.json",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "dev:webview": "vite",
    "vscode:prepublish": "npm run build",
    "package": "vsce package",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@opencode-ai/sdk": "latest",
    "@vscode/codicons": "^0.0.45",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "which": "^2.0.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^22.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.65.0",
    "@types/which": "^3.0.4",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/test-electron": "^1.1.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^17.0.5",
    "msw": "^2.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-sidebar",
          "title": "OpenCode",
          "icon": "assets/activitybar.svg"
        }
      ]
    },
    "views": {
      "opencode-sidebar": [
        {
          "type": "webview",
          "id": "opencode-sidebar.main",
          "name": "OpenCode"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-sidebar.focus",
        "title": "Focus OpenCode Sidebar",
        "category": "OpenCode"
      },
      {
        "command": "opencode-sidebar.createSession",
        "title": "New Session",
        "category": "OpenCode",
        "icon": "$(add)"
      },
      {
        "command": "opencode-sidebar.showHistory",
        "title": "History",
        "category": "OpenCode",
        "icon": "$(history)"
      },
      {
        "command": "opencode-sidebar.openSettings",
        "title": "Settings",
        "category": "OpenCode",
        "icon": "$(settings-gear)"
      },
      {
        "command": "opencode-sidebar.sendSelectionToOpencode",
        "title": "Send to OpenCode",
        "category": "OpenCode"
      },
      {
        "command": "opencode-sidebar.explainSelectionToOpencode",
        "title": "Explain Code",
        "category": "OpenCode"
      },
      {
        "command": "opencode-sidebar.sendTerminalToOpencode",
        "title": "Send Selected Lines to OpenCode",
        "category": "OpenCode"
      },
      {
        "command": "opencode-sidebar.explainTerminalToOpencode",
        "title": "Explain and Fix in OpenCode",
        "category": "OpenCode"
      },
      {
        "command": "opencode-sidebar.pasteAsPlainText",
        "title": "Paste as Plain Text",
        "category": "OpenCode"
      },
      {
        "command": "opencode-sidebar.closeAllSessions",
        "title": "Close All Sessions",
        "category": "OpenCode"
      },
      {
        "command": "opencode-sidebar.forkSession",
        "title": "Fork Session",
        "category": "OpenCode",
        "icon": "$(repo-forked)"
      }
    ],
    "menus": {
      "webview/context": [
        {
          "command": "opencode-sidebar.pasteAsPlainText",
          "when": "webviewId == 'opencode-sidebar.main' && webviewSection == 'promptInput'",
          "group": "paste@1"
        }
      ],
      "view/title": [
        {
          "command": "opencode-sidebar.createSession",
          "when": "view == opencode-sidebar.main",
          "group": "navigation@1"
        },
        {
          "command": "opencode-sidebar.showHistory",
          "when": "view == opencode-sidebar.main",
          "group": "navigation@2"
        },
        {
          "command": "opencode-sidebar.openSettings",
          "when": "view == opencode-sidebar.main",
          "group": "navigation@3"
        },
        {
          "command": "opencode-sidebar.forkSession",
          "when": "view == opencode-sidebar.main",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "opencode-sidebar.sendSelectionToOpencode",
          "when": "editorHasSelection && resourceScheme != 'output'",
          "group": "opencode@1"
        },
        {
          "command": "opencode-sidebar.explainSelectionToOpencode",
          "when": "editorHasSelection && resourceScheme != 'output'",
          "group": "opencode@2"
        },
        {
          "command": "opencode-sidebar.sendTerminalToOpencode",
          "when": "resourceScheme == 'output' && editorHasSelection",
          "group": "opencode@1"
        },
        {
          "command": "opencode-sidebar.explainTerminalToOpencode",
          "when": "resourceScheme == 'output' && editorHasSelection",
          "group": "opencode@2"
        }
      ],
      "terminal/context": [
        {
          "command": "opencode-sidebar.sendTerminalToOpencode",
          "group": "opencode@1"
        },
        {
          "command": "opencode-sidebar.explainTerminalToOpencode",
          "group": "opencode@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencode-sidebar.pasteAsPlainText",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "activeWebviewPanelId == 'opencode-sidebar.main'"
      }
    ],
    "configuration": {
      "title": "OpenCode Sidebar",
      "properties": {
        "opencode.model": {
          "type": "string",
          "default": "",
          "description": "Default model to use (format: provider/model)"
        },
        "opencode.agent": {
          "type": "string",
          "default": "",
          "description": "Default agent to use"
        },
        "opencode.historySize": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of prompts retained in input history (Up/Down recall)."
        },
        "opencode.serverTimeout": {
          "type": "number",
          "default": 15000,
          "minimum": 5000,
          "maximum": 120000,
          "description": "Timeout in milliseconds for the opencode server to start. Increase this on low-spec machines."
        },
        "opencode.executablePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the opencode executable. Leave empty to resolve from PATH. The binary must be named 'opencode' (or 'opencode.exe' on Windows)."
        }
      }
    }
  }
}
